@{
    Layout = "_AdminLayout";
}

<style>
    .dashboard-card {
        border: none;
        border-radius: 20px;
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        transition: .3s;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

    .stat-icon {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
    }

    .bg-soft-primary {
        background: #e8f1ff;
        color: #0d6efd;
    }

    .bg-soft-success {
        background: #e9f9ef;
        color: #198754;
    }

    .bg-soft-warning {
        background: #fff5df;
        color: #ffc107;
    }

    .bg-soft-danger {
        background: #ffecec;
        color: #dc3545;
    }

    .welcome-box {
        border-radius: 24px;
        background: linear-gradient(135deg, #111827, #374151);
        color: white;
        padding: 35px;
    }

    .table-card {
        border-radius: 20px;
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        padding: 25px;
    }

    .badge-sale {
        background: #e8f1ff;
        color: #0d6efd;
        padding: 7px 12px;
        border-radius: 30px;
    }

    .badge-rent {
        background: #e9f9ef;
        color: #198754;
        padding: 7px 12px;
        border-radius: 30px;
    }
</style>

<div class="container-fluid my-4 px-lg-4">

    <div class="welcome-box mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h2 class="fw-bold mb-2">Hoş Geldin, Admin 👋</h2>
                <p class="mb-0 text-white-50">
                    Emlak ilanlarını, kullanıcıları ve satış/kiralama işlemlerini buradan yönetebilirsin.
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="/Property/AddProperty" class="btn btn-light px-4 py-3 rounded-4">
                    + Yeni İlan Ekle
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Toplam İlan</p>
                        <h3 class="fw-bold mb-0">@ViewBag.PropertyCount</h3>
                    </div>
                    <div class="stat-icon bg-soft-primary">🏠</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Satılık İlan</p>
                        <h3 class="fw-bold mb-0">@ViewBag.SaleCount</h3>
                    </div>
                    <div class="stat-icon bg-soft-success">💰</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Kiralık İlan</p>
                        <h3 class="fw-bold mb-0">@ViewBag.RentCount</h3>
                    </div>
                    <div class="stat-icon bg-soft-warning">🔑</div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="dashboard-card p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Kullanıcı</p>
                        <h3 class="fw-bold mb-0">@ViewBag.UserCount</h3>
                    </div>
                    <div class="stat-icon bg-soft-danger">👤</div>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-4">

        <div class="col-lg-8">
            <div class="table-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Son Eklenen İlanlar</h4>
                    <a href="/Property/Index" class="btn btn-outline-dark btn-sm rounded-4">Tümünü Gör</a>
                </div>

                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>İlan</th>
                            <th>Şehir</th>
                            <th>Fiyat</th>
                            <th>Tür</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.LastProperties)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Title</td>
                                <td>@item.City</td>
                                <td>@item.Price.ToString("C", new System.Globalization.CultureInfo("tr-TR"))</td>
                                <td>
                                    @if (item.PropertyTypeId == 1)
                                    {
                                        <span class="badge-sale">Satılık</span>
                                    }
                                    else
                                    {
                                        <span class="badge-rent">Kiralık</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>

        <div class="col-lg-4">
            <div class="table-card">
                <h4 class="fw-bold mb-4">İlan Dağılımı</h4>

                <canvas id="propertyChart" height="230"></canvas>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ctx = document.getElementById('propertyChart');

    new Chart(ctx, {
    type: 'doughnut',
    data: {
    labels: ['Satılık', 'Kiralık'],
    datasets: [{
    data: [@ViewBag.SaleCount, @ViewBag.RentCount]
    }]
    },
    options: {
    cutout: '70%',
    plugins: {
    legend: {
    position: 'bottom'
    }
    }
    }
    });
</script>