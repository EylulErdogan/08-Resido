@model List<MyDpprProject.Models.Sale>

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Satış Listesi</h2>

        <a href="/Sale/AddSale" class="btn btn-dark">
            + Yeni Satış
        </a>
    </div>

    <div class="bg-white p-4 rounded-4 shadow-sm">

        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>İlan</th>
                    <th>Müşteri</th>
                    <th>Satış Tarihi</th>
                    <th>Tutar</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.SaleId</td>

                        <td>@item.Title</td>

                        <td>@item.FullName</td>

                        <td>@item.SaleDate.ToShortDateString()</td>

                        <td>
                            @item.TotalPrice.ToString("C", new System.Globalization.CultureInfo("tr-TR"))
                        </td>

                        <td class="text-end">

                            <a href="/Sale/UpdateSale/@item.SaleId"
                               class="btn btn-success btn-sm">
                                Güncelle
                            </a>

                            <a href="/Sale/DeleteSale/@item.SaleId"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Satış silinsin mi?')">
                                Sil
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>