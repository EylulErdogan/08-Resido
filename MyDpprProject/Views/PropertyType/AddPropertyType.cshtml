@model MyDpprProject.Models.PropertyType

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid">

    <h2 class="fw-bold mb-4">
        Yeni İlan Türü
    </h2>

    <form method="post">

        <div class="bg-white p-4 rounded-4 shadow-sm">

            <div class="mb-4">

                <label class="form-label">
                    İlan Türü
                </label>

                <input asp-for="TypeName"
                       class="form-control p-3"
                       placeholder="Örn: Satılık, Kiralık">

            </div>

            <button class="btn btn-dark px-5 py-3">
                Kaydet
            </button>

            <a href="/PropertyType/Index"
               class="btn btn-outline-dark px-5 py-3">
                İptal
            </a>

        </div>

    </form>

</div>