@model MyDpprProject.Models.Property

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <h2 class="fw-bold mb-4">Yeni İlan Oluştur</h2>

    <form method="post">
        <div class="bg-white p-4 rounded-4 shadow-sm">

            <div class="mb-3">
                <label class="form-label">Başlık</label>
                <input asp-for="Title" class="form-control p-3" placeholder="İlan başlığı giriniz">
            </div>

            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control p-3" rows="5" placeholder="Açıklama giriniz"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Fiyat</label>
                    <input asp-for="Price" class="form-control p-3" placeholder="Fiyat giriniz">
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">İlan Türü</label>
                    <input asp-for="PropertyTypeId" type="number" class="form-control p-3" placeholder="1 Satılık, 2 Kiralık">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Şehir</label>
                    <input asp-for="City" class="form-control p-3" placeholder="Şehir giriniz">
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">İlçe</label>
                    <input asp-for="District" class="form-control p-3" placeholder="İlçe giriniz">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Adres</label>
                <input asp-for="Address" class="form-control p-3" placeholder="Adres giriniz">
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Yatak Sayısı</label>
                    <input asp-for="BedCount" type="number" class="form-control p-3">
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Banyo Sayısı</label>
                    <input asp-for="BathCount" type="number" class="form-control p-3">
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Metrekare</label>
                    <input asp-for="SquareMeter" type="number" class="form-control p-3">
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Resim Url</label>
                <input asp-for="ImageUrl" class="form-control p-3" placeholder="item15.jpg">
            </div>

            <button type="submit" class="btn btn-dark px-5 py-3">Kaydet</button>
            <a href="/Property/Index" class="btn btn-outline-dark px-5 py-3">İptal</a>

        </div>
    </form>
</div>