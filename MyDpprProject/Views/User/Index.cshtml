@model List<MyDpprProject.Models.User>

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Müşteri Listesi</h2>
        <a href="/User/AddUser" class="btn btn-dark">+ Yeni Müşteri</a>
    </div>

    <div class="bg-white p-4 rounded-4 shadow-sm">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad</th>
                    <th>Email</th>
                    <th>Şifre</th>
                    <th>Rol</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Password</td>
                        <td>
                            <span class="badge bg-secondary">@item.RoleName</span>
                        </td>
                        <td class="text-end">
                            <a href="/User/UpdateUser/@item.UserId" class="btn btn-success btn-sm">Güncelle</a>
                            <a href="/User/DeleteUser/@item.UserId" class="btn btn-danger btn-sm"
                               onclick="return confirm('Bu müşteri silinsin mi?')">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>