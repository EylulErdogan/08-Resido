@model List<MyDpprProject.Models.Property>
<section id="page-billboard">
    <div class="container padding-medium-2 ">
        <div class="page-billboard-container text-center">
            <h1 class=" text-capitalize  lh-1 mb-3">Ev Listesi</h1>
            <span class="item"><a href="/">Anasayfa</a></span> &nbsp; / &nbsp; <span class="item">Ev Listesi</span>
        </div>
    </div>
</section>


<div class="container">
    <main class="main-content">
        <div class="row align-items-center pb-5">
           
            <div class="row align-items-center pb-5">

                <div class="row justify-content-center pb-5">
                    <div class="col-lg-10">
                        <div class="p-4 bg-white shadow-sm rounded-4 border">
                            <div class="row g-3 align-items-center">

                                <div class="col-md-7">
                                    <label class="form-label fw-semibold">İlan Ara</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white">
                                            🔍
                                        </span>
                                        <input type="text"
                                               id="searchInput"
                                               class="form-control p-3"
                                               placeholder="Başlık, şehir, ilçe veya adres ara...">
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">İlan Türü</label>
                                    <select id="typeFilter" class="form-select p-3">
                                        <option value="0">Tüm İlanlar</option>
                                        <option value="1">Satılık</option>
                                        <option value="2">Kiralık</option>
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-semibold invisible">Temizle</label>
                                    <button type="button"
                                            id="clearFilter"
                                            class="btn btn-dark w-100 p-3">
                                        Temizle
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        <div class="row">
            @foreach(var item in Model)
            {
                  <div class="col-md-6 col-lg-4 mb-3 property-card"
                     data-title="@item.Title.ToLower()"
                     data-city="@item.City.ToLower()"
                     data-district="@item.District.ToLower()"
                     data-address="@item.Address.ToLower()"
                     data-type="@item.PropertyTypeId">
                <div class="card">
                        <a href="/Property/PropertyViewById"><img src="~/images/@item.ImageUrl" class="card-img-top rounded-4" alt="Luxury apartment with modern kitchen"></a>
                    <div class="card-body p-0">
                            <h3 class="pt-4">
                                @item.Price.ToString("C", new System.Globalization.CultureInfo("tr-TR"))
                                <span class="text-muted fs-5">@item.TypeName</span>
                            </h3>
                            <a href="/Property/PropertyViewById">
                                <h4 class="card-title">@item.Title</h4>
                        </a>
                        <p class="card-text">@item.Address</p>

                        <div class="card-text border-top border-2 pt-3">
                            <ul class="d-flex">
                                <li class="residence-list pe-2 fw-semibold">
                                    <svg class="text-primary" width="30" height="30">
                                        <use xlink:href="#bed"></use>
                                        </svg> @item.BedCount yatak
                                </li>
                                <li class="residence-list pe-2 fw-semibold">
                                    <svg class="text-primary" width="30" height="30">
                                        <use xlink:href="#bath"></use>
                                        </svg> @item.BathCount banyo
                                </li>
                                <li class="residence-list pe-2 fw-semibold">
                                    <svg class="text-primary" width="30" height="30">
                                        <use xlink:href="#area"></use>
                                        </svg> @item.SquareMeter m2
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            }
   
        </div>

        <nav aria-label="Page navigation" class="d-flex justify-content-center pt-4 my-5">
            <ul class="pagination">
                <li class="page-item">
                    <a class="page-link" href="#" aria-label="Previous">
                        <iconify-icon icon="solar:arrow-left-linear" class="pagination-arrow">
                            <template shadowrootmode="open">
                                <style data-style="data-style">
                                                                    :host {
                                                                        display: inline-block;
                                                                        vertical-align: 0
                                                                    }

                                                                    span, svg {
                                                                        display: block
                                    }</style>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 12H4m0 0l6-6m-6 6l6 6"></path></svg>
                                </template>
                            </iconify-icon>
                        </a>
                    </li>
                    <li class="page-item active" aria-current="page">
                        <a class="page-link" href="#">1</a>
                    </li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">4</a></li>
                    <li class="page-item"><a class="page-link" href="#">5</a></li>
                    <li class="page-item">
                        <a class="page-link" href="#" aria-label="Next">
                            <iconify-icon icon="solar:arrow-right-linear" class="pagination-arrow">
                                <template shadowrootmode="open">
                                    <style data-style="data-style">
                                                                        :host {
                                                                            display: inline-block;
                                                                            vertical-align: 0
                                                                        }

                                                                        span, svg {
                                                                            display: block
                                        }</style>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h16m0 0l-6-6m6 6l-6 6"></path></svg>
                                    </template>
                                </iconify-icon>
                            </a>
                        </li>
                    </ul>
                </nav>
                <script>
                            const searchInput = document.getElementById("searchInput");
                            const typeFilter = document.getElementById("typeFilter");
                            const clearFilter = document.getElementById("clearFilter");

                            function filterProperties() {
                                const search = searchInput.value.toLowerCase();
                                const type = typeFilter.value;

                                document.querySelectorAll(".property-card").forEach(function (card) {
                                    const title = card.dataset.title;
                                    const city = card.dataset.city;
                                    const district = card.dataset.district;
                                    const address = card.dataset.address;
                                    const propertyType = card.dataset.type;

                                    const textMatch =
                                        title.includes(search) ||
                                        city.includes(search) ||
                                        district.includes(search) ||
                                        address.includes(search);

                                    const typeMatch = type === "0" || propertyType === type;

                                    card.style.display = textMatch && typeMatch ? "" : "none";
                                });
                            }

                            searchInput.addEventListener("keyup", filterProperties);
                            typeFilter.addEventListener("change", filterProperties);

                            clearFilter.addEventListener("click", function () {
                                searchInput.value = "";
                                typeFilter.value = "0";
                                filterProperties();
                            });
                </script>
            </main>
        </div>